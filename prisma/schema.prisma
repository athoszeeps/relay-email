generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model EmailLog {
  id          String      @id @default(uuid()) @db.UniqueIdentifier
  to          String      @db.NVarChar(255)
  from        String      @db.NVarChar(255)
  subject     String      @db.NVarChar(500)
  body        String      @db.NVarChar(Max)
  replyTo     String?     @db.NVarChar(255)
  status      String      @default("pending") @db.NVarChar(20)
  attempts    Int         @default(0)
  lastError   String?     @db.NVarChar(Max)
  createdAt   DateTime    @default(now())
  sentAt      DateTime?
  nextRetryAt DateTime?

  @@index([status, createdAt])
  @@map("email_logs")
}
